{
  "env": {
    "ANTHROPIC_BASE_URL": "http://localhost:8080",
    "ANTHROPIC_AUTH_TOKEN": "dummy-gateway-token",
    "ANTHROPIC_CUSTOM_HEADERS": "x-portkey-metadata: {\"_user\":\"diogo.pereira-marques@roche.com\",\"ona_user_id\":\"019d0332-cb44-724b-ad3f-525da52a87d4\",\"tool\":\"claude\"}",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Bash(docker compose:*)",
      "Bash(docker exec:*)",
      "Bash(~/.claude/hooks/log-step-event.sh*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/log-session-start.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/log-session-end.sh"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/log-subagent-start.sh"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/log-subagent-stop.sh"
          }
        ]
      }
    ]
  }
}
