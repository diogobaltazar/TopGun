{
  "env": {
    "ANTHROPIC_BASE_URL": "http://localhost:8080",
    "ANTHROPIC_AUTH_TOKEN": "dummy-gateway-token",
    "ANTHROPIC_CUSTOM_HEADERS": "x-portkey-metadata: {\"_user\":\"diogo.pereira-marques@roche.com\",\"ona_user_id\":\"019d0332-cb44-724b-ad3f-525da52a87d4\",\"tool\":\"claude\"}",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Bash(~/.claude/hooks/log-subagent-events.sh*)",
      "Bash(~/.claude/hooks/log-message-events.sh*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git status*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git checkout -b*)",
      "Bash(git worktree*)",
      "Bash(git branch*)",
      "Bash(git remote get-url*)",
      "Bash(ls*)",
      "Bash(pwd*)",
      "Bash(find*)",
      "Bash(du*)",
      "Bash(df*)",
      "Bash(wc*)",
      "Bash(file*)",
      "Bash(cat*)",
      "Bash(head*)",
      "Bash(tail*)",
      "Bash(grep*)",
      "Bash(sort*)",
      "Bash(uniq*)",
      "Bash(awk*)",
      "Bash(jq*)",
      "Bash(ps*)",
      "Bash(uptime*)",
      "Bash(uname*)",
      "Bash(which*)",
      "Bash(type*)",
      "Bash(env*)",
      "Bash(printenv*)",
      "Bash(docker ps*)",
      "Bash(docker images*)",
      "Bash(docker logs*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "HOOK_EVENT=PostToolUse:SendMessage ~/.claude/hooks/log-message-events.sh",
            "type": "command"
          }
        ],
        "matcher": "SendMessage"
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "command": "HOOK_EVENT=SubagentStart ~/.claude/hooks/log-subagent-events.sh",
            "type": "command"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "command": "HOOK_EVENT=SubagentStop ~/.claude/hooks/log-subagent-events.sh",
            "type": "command"
          }
        ]
      }
    ]
  }
}
