# ── Anthropic credentials ──────────────────────────────────────────────────
#
# topgun task add and topgun task start (fuzzy match) call Claude Haiku via
# the Anthropic SDK. One of the two options below must be configured.
#
# Option A — build-cli (Roche / Anthropic internal setup)
#
#   build-cli stores an encrypted session in ~/.local/share/build-cli/ and
#   exposes it via: build-cli auth token
#
#   Because build-cli is a macOS arm64 binary it cannot run inside the Alpine
#   Docker container. Export the token on the host before running topgun:
#
#     export ANTHROPIC_API_KEY=$(build-cli auth token)
#
#   Tokens expire (typically after several hours). Add the line above to a
#   shell hook or re-run it when you see an authentication error.
#   compose.yml passes ANTHROPIC_API_KEY through to the container automatically.
#
# Option B — direct API key
#
#   Paste a key from console.anthropic.com. Does not expire.
#
ANTHROPIC_API_KEY=

# Option C — auth helper binary (for native / non-Docker installs only)
#
#   If topgun is installed natively (not via Docker) and a helper binary that
#   implements `<binary> auth token` is on your PATH, set it here.
#   Example: TOPGUN_AUTH_HELPER=claude
#
TOPGUN_AUTH_HELPER=

# Anthropic API base URL — set only if using a corporate proxy.
ANTHROPIC_BASE_URL=
